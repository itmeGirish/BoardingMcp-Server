{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReviewNode",
  "description": "Schema for structured review output used by the drafting review node",
  "type": "object",
  "required": ["review"],
  "properties": {
    "review": {
      "$ref": "#/definitions/review"
    }
  },
  "definitions": {
    "review": {
      "type": "object",
      "required": ["review_pass"],
      "properties": {
        "review_pass": {
          "type": "boolean",
          "description": "True if no blocking issues were found"
        },
        "blocking_issues": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/review_issue"
          }
        },
        "non_blocking_issues": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/review_issue"
          }
        },
        "unsupported_statements": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/unsupported_statement"
          }
        },
        "final_artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/draft_artifact"
          }
        }
      }
    },
    "review_issue": {
      "type": "object",
      "required": ["issue", "fix", "location"],
      "properties": {
        "issue": {
          "type": "string"
        },
        "fix": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": ["legal", "formatting"],
          "default": "legal"
        }
      }
    },
    "unsupported_statement": {
      "type": "object",
      "required": ["statement", "reason"],
      "properties": {
        "statement": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "location": {
          "type": ["string", "null"]
        }
      }
    },
    "draft_artifact": {
      "type": "object",
      "required": ["doc_type", "title", "text"],
      "properties": {
        "doc_type": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "placeholders_used": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/placeholder_used"
          }
        },
        "citations_used": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "placeholder_used": {
      "type": "object",
      "required": ["key", "reason"],
      "properties": {
        "key": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      }
    }
  }
}
